# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Bot token from https://discord.com/developers/applications -> Bot
DISCORD_TOKEN=

# Application (client) ID from the same page -> General Information
CLIENT_ID=

# Your Discord user ID (enable Developer Mode -> right-click your name -> Copy User ID)
# This user receives storage warning DMs in addition to server admins
OWNER_ID=

# -----------------------------------------------------------------------------
# Optional (defaults shown)
# -----------------------------------------------------------------------------

# Max sounds a single user can have uploaded at once
MAX_SOUNDS_PER_USER=20

# Max duration of a single sound in seconds (hard cap)
MAX_DURATION_SECONDS=120

# Max size of a single sound AFTER conversion, in megabytes
MAX_FILE_SIZE_MB=10

# When total sounds folder size crosses this threshold (GB), send warning DMs
STORAGE_WARN_GB=1

# Hard cap on total sounds folder size (GB). Uploads are rejected at or above this
STORAGE_HARD_GB=5
